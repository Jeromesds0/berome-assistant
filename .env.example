# ── LLM Provider ──────────────────────────────────────────────────────────────
# "anthropic" or "ollama"
BEROME_PROVIDER=anthropic

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
BEROME_ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Ollama (local) ────────────────────────────────────────────────────────────
BEROME_OLLAMA_BASE_URL=http://localhost:11434
BEROME_OLLAMA_MODEL=llama3.1

# ── GitHub ────────────────────────────────────────────────────────────────────
GITHUB_TOKEN=ghp_...
GITHUB_USERNAME=your-github-username

# ── Agent system ──────────────────────────────────────────────────────────────
BEROME_MAX_AGENTS=5
BEROME_AGENT_TIMEOUT=120

# ── Discord Bot ────────────────────────────────────────────────────────────────
# Get your token from https://discord.com/developers/applications
DISCORD_BOT_TOKEN=your-discord-bot-token
# Set to false to respond to all messages without needing @mention
DISCORD_REQUIRE_MENTION=true
# Comma-separated channel IDs where bot responds without @mention (optional)
# DISCORD_ALLOWED_CHANNELS=123456789,987654321
# Auto-approve all shell command tool calls — only enable on private/trusted servers
DISCORD_AUTO_APPROVE_TOOLS=false
